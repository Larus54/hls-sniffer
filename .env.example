# GitHub target
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
GITHUB_JSON_PATH=data/hls_streams.json

# Local monitor list (JSON file)
MONITOR_URLS_FILE=monitor_urls.json

# 30 minuti = 1800 secondi
SYNC_INTERVAL_SECONDS=1800

# HTTP timeout for GitHub API
GITHUB_REQUEST_TIMEOUT_SECONDS=30
